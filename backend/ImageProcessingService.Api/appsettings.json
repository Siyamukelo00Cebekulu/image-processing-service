{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=image-processing.db"
  },
  "Jwt": {
    "Issuer": "ImageProcessingService",
    "Audience": "ImageProcessingService.Client",
    "SecretKey": "replace-this-with-a-long-random-secret-key-for-production",
